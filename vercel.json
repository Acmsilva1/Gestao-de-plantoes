{
  "version": 2,
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/web/assets/$1"
    },
    {
      "src": "/icons/(.*)",
      "dest": "/web/icons/$1"
    },
    {
      "src": "/manifest.webmanifest",
      "dest": "/web/manifest.webmanifest"
    },
    {
      "src": "/sw.js",
      "dest": "/web/sw.js"
    },
    {
      "src": "/offline.html",
      "dest": "/web/offline.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/web/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/web/index.html"
    }
  ]
}
