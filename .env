# Dados locais: CSV em ./dblocal (sem SQLite). Opcional: GDP_DBLLOCAL_CSV_DIR=C:\caminho\para\dblocal
DISABLE_PREDICTOR_SCHEDULER=true

# Cache Redis (prod-like)
ENABLE_REDIS=1
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=gdp
ESCALA_EDITOR_CACHE_TTL_SEC=45

# Mensageria RabbitMQ (prod-like)
ENABLE_QUEUE=1
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_EXCHANGE=gestao.events

PORT=3000
