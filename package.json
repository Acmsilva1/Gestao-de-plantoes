{
  "name": "gestao-de-plantoes",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run web:build",
    "dev": "node --watch server.js",
    "start": "node server.js",
    "web:dev": "npm --prefix web run dev -- --host localhost --port 5173 --strictPort",
    "web:build": "npm --prefix web run build",
    "web:preview": "npm --prefix web run preview",
    "dev:full": "concurrently \"npm run dev\" \"npm run web:dev\"",
    "pipeline:watch": "python pipeline_guard.py",
    "pipeline:once": "python pipeline_guard.py --once",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:path": "git config --get core.hooksPath",
    "infra:up": "docker compose -f docker-compose.infra.yml up -d",
    "infra:down": "docker compose -f docker-compose.infra.yml down",
    "infra:logs": "docker compose -f docker-compose.infra.yml logs -f --tail=150"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "amqplib": "^1.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "node-cron": "^4.2.1",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
