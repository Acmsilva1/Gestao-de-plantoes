{
  "name": "gestao-de-plantoes",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "build": "npm run build -w web",
    "dev": "npm run dev -w api",
    "start": "npm run start -w api",
    "dev:web": "npm run dev -w web -- --host localhost --port 5180 --strictPort",
    "dev:web:5180": "npm run dev -w web -- --host 127.0.0.1 --port 5180 --strictPort",
    "dev:full:5180": "concurrently -n api,web -c blue,magenta \"npm run dev\" \"npm run dev:web:5180\"",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:web\"",
    "web:dev": "npm run dev:web",
    "web:dev:5180": "npm run dev:web:5180",
    "web:build": "npm run build -w web",
    "web:preview": "npm run preview -w web",
    "preview": "npm run preview -w web",
    "pipeline:watch": "python scripts/pipeline_guard.py",
    "pipeline:once": "python scripts/pipeline_guard.py --once",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:path": "git config --get core.hooksPath",
    "infra:up": "docker compose -f infra/docker-compose.infra.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.infra.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.infra.yml logs -f --tail=150",
    "sql:run": "npm run sql:run -w api",
    "etl": "npm run etl -w api",
    "dblocal:export": "node api/scripts/export-dblocal-csv.mjs",
    "dblocal:import": "node api/scripts/import-dblocal-csv.mjs",
    "test": "npm run test -w api",
    "lint": "npm run lint -w web",
    "check": "npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
