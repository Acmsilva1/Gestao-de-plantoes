{
  "name": "gestao-de-plantoes",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build -w gestao-de-plantoes-web",
    "dev": "npm run dev -w gestao-de-plantoes-backend",
    "start": "npm run start -w gestao-de-plantoes-backend",
    "frontend:dev": "npm run dev -w gestao-de-plantoes-web -- --host localhost --port 5173 --strictPort",
    "frontend:dev:5180": "npm run dev -w gestao-de-plantoes-web -- --host 127.0.0.1 --port 5180 --strictPort",
    "dev:full:5180": "concurrently -n api,web -c blue,magenta \"npm run dev\" \"npm run frontend:dev:5180\"",
    "frontend:build": "npm run build -w gestao-de-plantoes-web",
    "frontend:preview": "npm run preview -w gestao-de-plantoes-web",
    "dev:full": "concurrently \"npm run dev\" \"npm run frontend:dev\"",
    "web:dev": "npm run frontend:dev",
    "web:dev:5180": "npm run frontend:dev:5180",
    "web:build": "npm run frontend:build",
    "web:preview": "npm run frontend:preview",
    "pipeline:watch": "python backend/pipeline_guard.py",
    "pipeline:once": "python backend/pipeline_guard.py --once",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:path": "git config --get core.hooksPath",
    "infra:up": "docker compose -f backend/docker-compose.infra.yml up -d",
    "infra:down": "docker compose -f backend/docker-compose.infra.yml down",
    "infra:logs": "docker compose -f backend/docker-compose.infra.yml logs -f --tail=150",
    "sql:run": "npm run sql:run -w gestao-de-plantoes-backend",
    "etl": "npm run etl -w gestao-de-plantoes-backend",
    "dblocal:export": "node backend/scripts/export-dblocal-csv.mjs",
    "dblocal:import": "node backend/scripts/import-dblocal-csv.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
