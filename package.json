{
  "name": "gestao-de-plantoes",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "web:dev": "npm --prefix web run dev -- --host localhost --port 5173 --strictPort",
    "web:build": "npm --prefix web run build",
    "web:preview": "npm --prefix web run preview",
    "dev:full": "concurrently \"npm run dev\" \"npm run web:dev\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
