# Copiar para `.env` na raiz do repositório (não commitar segredos reais).

# API
GDP_API_PORT=3000
PORT=3000

# Dados locais (Parquet/CSV); por omissão: ./api/data/local
# GDP_DBLLOCAL_CSV_DIR=C:/caminho/absoluto/para/dados

GDP_DEMO_READ_ONLY=true
GDP_DBLLOCAL_SKIP_BOOT_PARQUET_SNAPSHOT=

# Opcional: Redis / RabbitMQ
ENABLE_REDIS=false
REDIS_URL=redis://127.0.0.1:6379
ENABLE_QUEUE=false
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672

DISABLE_PREDICTOR_SCHEDULER=
